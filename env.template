# ── Databoutique Bid Monitor — Config ──────────────────────────
# 1. Copy this file:   cp .env.template .env
# 2. Fill in values below
# 3. Secure it:        chmod 600 .env
# 4. Run:              python3 bid_monitor.py
# ───────────────────────────────────────────────────────────────

# Paste your full cookie string from browser DevTools here.
DATABOUTIQUE_COOKIE=PASTE_YOUR_COOKIE_STRING_HERE

# Your Telegram Bot token — from @BotFather
TELEGRAM_BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE

# Your Telegram chat ID — from @userinfobot
TELEGRAM_CHAT_ID=PASTE_YOUR_CHAT_ID_HERE

# How often to check in seconds. Default = 900 (15 minutes)
# Examples: 300 = 5min | 600 = 10min | 1800 = 30min | 3600 = 1hr
CHECK_INTERVAL=900
